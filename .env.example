# ──────────────────────────────────────────────────────────────
# adhd-dashboard — environment variables
# Copy to `.env` (local dev) and provide real values.
# `.env*` is git-ignored; this `.env.example` is the committed reference.
# ──────────────────────────────────────────────────────────────

# ── Database (Postgres) ───────────────────────────────────────
# Prisma connection string consumed by the app (via @prisma/adapter-pg).
# Local dev:        postgresql://USER:PASSWORD@localhost:5432/adhd_dashboard
# In docker-compose: host is the postgres service name (e.g. `db`):
#                   postgresql://USER:PASSWORD@db:5432/adhd_dashboard
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/adhd_dashboard"

# Used by the Postgres container (docker-compose) to initialise the DB.
# Keep these in sync with DATABASE_URL above.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="adhd_dashboard"

# ── Better Auth ───────────────────────────────────────────────
# Secret used for token signing/encryption (min 32 chars).
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Base URL of the app. Locally: http://localhost:3000
# In production: the public cloudflared hostname, e.g. https://adhd.example.com
# (Behind the tunnel, also add this origin to `trustedOrigins` in your auth config.)
BETTER_AUTH_URL="http://localhost:3000"

# ── Logging ───────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal | silent
# Defaults: "debug" in development, "info" in production.
LOG_LEVEL="debug"

# ── Initial admin user (consumed by the seed script) ──────────
# The single account created on first `prisma db seed`.
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="change-me-before-seeding"

# ── Email (transactional) ─────────────────────────────────────
# Default: Resend (https://resend.com) — free tier 3,000/mo.
RESEND_API_KEY=""
EMAIL_FROM="ADHD Dashboard <noreply@example.com>"

# Alternative: plain SMTP (e.g. Brevo, Gmail app password) instead of Resend.
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""

# ── Cloudflare Tunnel (cloudflared sidecar) ───────────────────
# Token from `cloudflared tunnel` / the Zero Trust dashboard.
TUNNEL_TOKEN=""
